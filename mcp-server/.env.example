# MCP Server — Environment Variables
# Copy this file to mcp-server/.env and fill in the values.
# The MCP server runs separately from the Next.js app on port 3001 by default.

SUPABASE_URL=                     # Required — your Supabase project URL
SUPABASE_SERVICE_ROLE_KEY=        # Required — service role key (bypasses RLS)
MCP_PROXY_SECRET=                 # Required — shared secret for MCP proxy auth (must match MCP_PROXY_SECRET in root .env.local)
MCP_SERVER_PORT=3001              # Has-Default
MCP_SERVER_HOST=localhost         # Has-Default
